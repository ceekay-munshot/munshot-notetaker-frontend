{
  "name": "munshot-notetaker-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Munshot Notetaker — a React dashboard (meetings intelligence) served by a Cloudflare Worker that handles auth, transcripts, scheduling, calendar, and the meeting assistant.",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "jspdf": "^3.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wrangler": "^3.114.17"
  }
}
